COMPOSE_PROJECT_NAME=personal-crm

MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=personal_crm
MYSQL_USER=personal_crm
MYSQL_PASSWORD=change_me_mysql_password
MYSQL_ROOT_PASSWORD=change_me_mysql_root_password

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DATABASE=1
REDIS_PASSWORD=
REDIS_TIMEOUT_MS=3000

SERVER_PORT=8080
SPRING_SQL_INIT_MODE=always
JWT_SECRET=change_me_jwt_secret_at_least_32_chars
JWT_EXPIRATION_SECONDS=7200

UPLOAD_DIR=/app/uploads
CONTACT_AVATAR_DIR=contact-avatar
USER_AVATAR_DIR=user-avatar

OPENAI_API_KEY=mock-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

RESEND_API_KEY=mock-key
RESEND_FROM_EMAIL=Personal CRM <no-reply@example.com>

QWEATHER_API_KEY=replace_with_real_qweather_key
QWEATHER_API_HOST=nk3dnacruh.re.qweatherapi.com
IP_API_URL=http://ip-api.com/json/
WEATHER_DEFAULT_CITY=Hangzhou

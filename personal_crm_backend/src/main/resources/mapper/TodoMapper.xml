<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.weiqiang.personal_crm_backend.mapper.TodoMapper">

    <select id="selectTodoPage" resultType="com.weiqiang.personal_crm_backend.model.vo.TodoVO">
        SELECT
            t.matter_id AS matterId,
            t.contact_id AS contactId,
            c.name AS contactName,
            t.todo_time AS todoTime,
            t.content,
            t.status,
            t.priority,
            t.completed_at AS completedAt,
            t.cancelled_at AS cancelledAt,
            t.created_at AS createdAt
        FROM contact_todo t
        LEFT JOIN contact c ON t.contact_id = c.ct_id
        <where>
            t.user_id = #{userId}
            <if test="query.contactId != null and query.contactId != ''">
                AND t.contact_id = #{query.contactId}
            </if>
            <if test="query.status != null">
                AND t.status = #{query.status}
            </if>
            <if test="query.startTime != null and query.startTime != ''">
                AND t.todo_time &gt;= #{query.startTime}
            </if>
            <if test="query.endTime != null and query.endTime != ''">
                AND t.todo_time &lt;= #{query.endTime}
            </if>
        </where>
        ORDER BY 
        <choose>
            <when test="query.sortBy != null and query.sortBy == 'createdAt'">
                t.created_at
            </when>
            <when test="query.sortBy != null and query.sortBy == 'completedAt'">
                t.completed_at
            </when>
            <when test="query.sortBy != null and query.sortBy == 'cancelledAt'">
                t.cancelled_at
            </when>
            <otherwise>
                t.status ASC, t.todo_time
            </otherwise>
        </choose>
        <choose>
            <when test="query.sortOrder != null and query.sortOrder.equalsIgnoreCase('desc')">
                DESC
            </when>
            <otherwise>
                ASC
            </otherwise>
        </choose>
    </select>

</mapper>
